{
  "kind": "collectionType",
  "collectionName": "apps",
  "info": {
    "singularName": "app",
    "pluralName": "apps",
    "displayName": "App",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "icon": {
      "type": "string",
      "default": "📁"
    },
    "iconImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "color": {
      "type": "string"
    },
    "order": {
      "type": "integer"
    },
    "works": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::work.work",
      "mappedBy": "app"
    }
  }
}
